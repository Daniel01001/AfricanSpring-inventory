@page
@model AfricanSpringInventory.Pages.Deliveries.CreateModel
@{
    ViewData["Title"] = "Log a delivery";
    ViewData["Sub"] = "Stock is deducted automatically";
    ViewData["FlowFoot"] = true;
}

<a class="back" asp-page="/Index"><svg class="icon"><use href="#i-back" /></svg> Home</a>
<h1 class="page-title">Log a delivery</h1>
<p class="page-sub">Stock is deducted automatically.</p>

<form method="post" id="deliveryForm">
    <div class="field">
        <label asp-for="StoreId">Store</label>
        <select asp-for="StoreId" asp-items="Model.Stores">
            <option value="">Select a store…</option>
        </select>
    </div>

    <div class="field">
        <label asp-for="DeliveryDate">Date</label>
        <input asp-for="DeliveryDate" type="date" />
    </div>

    <div class="field">
        <label>Products</label>
        @if (Model.Lines.Count == 0)
        {
            <div class="empty">No products set up yet.</div>
        }
        else
        {
            <div class="card" style="padding:4px 16px">
                @for (var i = 0; i < Model.Lines.Count; i++)
                {
                    <div class="prow">
                        <span class="p-main">
                            <span class="p-t">@Model.Lines[i].Name</span><br />
                            <span class="p-s">R @Model.Lines[i].UnitPrice.ToString("N2") / @Model.Lines[i].UnitType</span>
                        </span>
                        <span class="stepper">
                            <button type="button" data-step="-1" aria-label="Less @Model.Lines[i].Name">&minus;</button>
                            <input asp-for="Lines[i].Quantity" type="number" min="0" step="0.01"
                                   inputmode="decimal" placeholder="0" data-price="@Model.Lines[i].UnitPrice" />
                            <button type="button" data-step="1" aria-label="More @Model.Lines[i].Name">+</button>
                        </span>
                        <input type="hidden" asp-for="Lines[i].ProductId" />
                    </div>
                }
            </div>
        }
    </div>

    <div class="field" style="margin-top:8px">
        <label asp-for="Notes">Notes</label>
        <textarea asp-for="Notes" placeholder="Optional"></textarea>
    </div>

    @if (Model.Error is not null)
    {
        <p class="field-error">@Model.Error</p>
    }

    <div class="flowfoot">
        <span class="ff-total"><span class="ff-lbl">Total</span>R <span id="grand-total">0.00</span></span>
        <button class="btn btn-primary" type="submit">
            <svg class="icon"><use href="#i-plus" /></svg> Save delivery
        </button>
    </div>
</form>

@section Scripts {
    <script>
        (function () {
            const qtys = document.querySelectorAll('.stepper input[type=number]');
            const out = document.getElementById('grand-total');
            function recalc() {
                let total = 0;
                qtys.forEach(function (i) {
                    total += (parseFloat(i.value) || 0) * (parseFloat(i.dataset.price) || 0);
                });
                if (out) out.textContent = total.toFixed(2);
            }
            qtys.forEach(function (i) { i.addEventListener('input', recalc); });
            document.querySelectorAll('.stepper [data-step]').forEach(function (b) {
                b.addEventListener('click', function () {
                    const input = b.parentElement.querySelector('input[type=number]');
                    const next = (parseFloat(input.value) || 0) + parseInt(b.dataset.step, 10);
                    input.value = next > 0 ? next : '';
                    recalc();
                });
            });
            recalc();
        })();
    </script>
}
