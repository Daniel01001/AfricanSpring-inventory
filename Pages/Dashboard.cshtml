@page
@model AfricanSpringInventory.Pages.DashboardModel
@{
    ViewData["Title"] = "Overview";
    ViewData["Tab"] = "dashboard";
    ViewData["Wide"] = true;
    ViewData["Sub"] = DateTime.Now.ToString("dddd, d MMMM");
}

<div class="page-head" style="margin-bottom:18px">
    <div>
        <h1 class="page-title">Dashboard</h1>
        <p class="page-sub" style="margin:0">A quick pulse on deliveries, revenue and stock.</p>
    </div>
</div>

<div class="kpi-grid">
    <div class="kpi">
        <div class="kpi-top">
            <span class="kpi-label">Total revenue</span>
            <span class="kpi-chip"><svg class="icon"><use href="#i-trend" /></svg></span>
        </div>
        <div class="kpi-value">R @Model.TotalRevenue.ToString("N0")</div>
        <svg class="spark" viewBox="0 0 100 30" preserveAspectRatio="none"><polyline points="@Model.SparkPoints" /></svg>
        <div class="kpi-sub">all time · last 7 days</div>
    </div>
    <div class="kpi">
        <div class="kpi-top">
            <span class="kpi-label">Total deliveries</span>
            <span class="kpi-chip"><svg class="icon"><use href="#i-truck" /></svg></span>
        </div>
        <div class="kpi-value">@Model.TotalDeliveryCount</div>
        <div class="kpi-sub">@Model.DeliveriesThisWeek this week · @Model.UnitsThisWeek.ToString("0.##") units</div>
    </div>
    <div class="kpi">
        <div class="kpi-top">
            <span class="kpi-label">Outstanding</span>
            <span class="kpi-chip"><svg class="icon"><use href="#i-wallet" /></svg></span>
        </div>
        <div class="kpi-value @(Model.TotalOutstanding > 0 ? "neg" : "")">R @Model.TotalOutstanding.ToString("N0")</div>
        <div class="kpi-sub">@Model.OwingCount store(s) owe</div>
    </div>
    <div class="kpi">
        <div class="kpi-top">
            <span class="kpi-label">Stock on hand</span>
            <span class="kpi-chip"><svg class="icon"><use href="#i-snowflake" /></svg></span>
        </div>
        <div class="kpi-value">@Model.StockUnits.ToString("0.##")</div>
        <div class="kpi-sub">@Model.ProductCount products</div>
    </div>
</div>

<div style="margin-top:14px">
    @if (Model.PendingApprovals > 0)
    {
        <a class="db-banner accent" asp-page="/Approvals/Index">
            <span class="b-ic"><svg class="icon"><use href="#i-store" /></svg></span>
            <span>
                <span class="b-t">@Model.PendingApprovals online sign-up@(Model.PendingApprovals == 1 ? "" : "s") to review</span>
                <span class="b-s">Approve or decline new businesses</span>
            </span>
            <svg class="icon b-chev"><use href="#i-chevron" /></svg>
        </a>
    }
    @if (Model.NewOrders > 0)
    {
        <a class="db-banner accent" asp-page="/Orders/Index">
            <span class="b-ic"><svg class="icon"><use href="#i-order" /></svg></span>
            <span>
                <span class="b-t">@Model.NewOrders new website order@(Model.NewOrders == 1 ? "" : "s")</span>
                <span class="b-s">Tap to review and confirm</span>
            </span>
            <svg class="icon b-chev"><use href="#i-chevron" /></svg>
        </a>
    }

    @if (Model.LowStock.Count > 0)
    {
        <a class="db-banner warn" asp-page="/Stock/Index">
            <span class="b-ic"><svg class="icon"><use href="#i-snowflake" /></svg></span>
            <span>
                <span class="b-t">@Model.LowStock.Count product@(Model.LowStock.Count == 1 ? "" : "s") running low</span>
                <span class="b-s">@string.Join(", ", Model.LowStock.Select(s => s.Name))</span>
            </span>
            <svg class="icon b-chev"><use href="#i-chevron" /></svg>
        </a>
    }
</div>

<a class="btn btn-primary btn-block" asp-page="/Deliveries/Create">
    <svg class="icon"><use href="#i-truck" /></svg> Log a delivery
</a>

<div class="page-head" style="margin:24px 0 10px">
    <h2 class="section-label" style="margin:0">Recent deliveries</h2>
    <a class="view-all" asp-page="/Activity">View all →</a>
</div>
@if (Model.Recent.Count == 0)
{
    <div class="empty">No deliveries yet.</div>
}
else
{
    <div class="list">
        @foreach (var d in Model.Recent)
        {
            <a class="list-row" asp-page="/Stores/Details" asp-route-id="@d.StoreId">
                <span class="row-main">
                    <span class="primary">@d.Store</span><br />
                    <span class="secondary">@d.Date.ToString("dd MMM") · @d.Items</span>
                </span>
                <span class="amount">R @d.Total.ToString("N2")</span>
            </a>
        }
    </div>
}

<div class="cols" style="margin-top:20px">
    <div class="card">
        <h2 class="section-label" style="margin:0 0 6px">Pipeline</h2>
        @foreach (var p in Model.Pipeline)
        {
            <div class="pipe-row">
                <span class="p-name">@p.Status.Label()</span>
                <span class="pipe-count">@p.Count</span>
            </div>
        }
    </div>

    @if (Model.Outstanding.Count > 0)
    {
        <div class="card">
            <h2 class="section-label" style="margin:0 0 8px">Outstanding by store</h2>
            <div class="list" style="border:none;box-shadow:none">
                @foreach (var o in Model.Outstanding)
                {
                    <div class="list-row" style="padding-left:0;padding-right:0">
                        <span class="row-main"><span class="primary">@o.Name</span></span>
                        <span class="amount" style="color:var(--danger)">R @o.Amount.ToString("N2")</span>
                    </div>
                }
            </div>
        </div>
    }
</div>
