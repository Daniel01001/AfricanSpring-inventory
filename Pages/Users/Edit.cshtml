@page
@model AfricanSpringInventory.Pages.Users.EditModel
@{
    ViewData["Title"] = "Edit person";
}

<a class="back" asp-page="/Users/Index"><svg class="icon"><use href="#i-back" /></svg> People</a>
<h1 class="page-title">@Model.Name</h1>
<p class="page-sub">Update details, reset their PIN, or disable access.</p>

<form method="post" class="narrow">
    <input type="hidden" asp-for="Id" />

    <div class="field">
        <label asp-for="Name">Name</label>
        <input asp-for="Name" autocomplete="off" />
    </div>

    <div class="field-row">
        <div class="field">
            <label asp-for="NewPin">New PIN</label>
            <input asp-for="NewPin" type="password" inputmode="numeric" pattern="[0-9]*"
                   minlength="4" maxlength="8" placeholder="Leave blank to keep" autocomplete="new-password" />
        </div>
        <div class="field">
            <label asp-for="Role">Role</label>
            <select asp-for="Role" disabled="@Model.IsSelf">
                <option value="Friend">Friend — logs updates</option>
                <option value="Owner">Owner — full access</option>
            </select>
        </div>
    </div>
    @if (Model.IsSelf)
    {
        <input type="hidden" asp-for="Role" />
    }

    @if (!Model.IsSelf)
    {
        <label class="toggle">
            <input type="checkbox" asp-for="IsActive" />
            <span>Can sign in</span>
        </label>
    }
    else
    {
        <input type="hidden" asp-for="IsActive" />
        <p class="hint muted">This is your own account — you can't disable it.</p>
    }

    @if (Model.Error is not null)
    {
        <p class="field-error">@Model.Error</p>
    }

    <div class="action-bar">
        <button class="btn btn-primary btn-block" type="submit">Save changes</button>
    </div>
</form>
