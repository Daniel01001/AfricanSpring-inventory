@page
@model AfricanSpringInventory.Pages.Stock.IndexModel
@{
    ViewData["Title"] = "Stock";
    ViewData["Tab"] = "stock";
    ViewData["Wide"] = true;
    ViewData["Sub"] = "On hand";
}

<div class="page-head">
    <h1 class="page-title">Stock</h1>
</div>
<p class="page-sub">On hand across your products.</p>

@if (Model.Rows.Count == 0)
{
    <div class="empty" style="margin-top:18px">No products yet. Add one under Products first.</div>
}
else
{
    <div class="list-head">
        <span class="section-label" style="margin:0">On hand</span>
        <a class="add-link" asp-page="/Stock/Create"><svg class="icon"><use href="#i-plus" /></svg> Made ice</a>
    </div>

    <div class="list">
        @foreach (var r in Model.Rows)
        {
            <div class="list-row">
                <span class="avatar ghost"><svg class="icon"><use href="#i-snowflake" /></svg></span>
                <span class="row-main">
                    <span class="primary">
                        @r.Name
                        @if (r.Low)
                        {
                            <span class="badge intalks">Low</span>
                        }
                    </span><br />
                    <span class="secondary">
                        R @r.Price.ToString("N2") / @r.Unit@if (r.LastUpdated is not null)
                        {<text> · updated @r.LastUpdated.Value.ToString("dd MMM")</text>}
                    </span>
                </span>
                <span class="stock-onhand">
                    <span class="n">@r.OnHand.ToString("0.##")</span><br />
                    <span class="u">@r.Unit</span>
                </span>
            </div>
        }
    </div>

    <a class="btn btn-block" asp-page="/Stock/Create" style="margin-top:14px">
        <svg class="icon"><use href="#i-plus" /></svg> Record production
    </a>
}
