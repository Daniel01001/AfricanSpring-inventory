@page
@model AfricanSpringInventory.Pages.Orders.IndexModel
@{
    ViewData["Title"] = "Orders";
    ViewData["Tab"] = "orders";
    ViewData["Sub"] = "From the website";
    var statuses = Enum.GetValues<OrderStatus>();

    static string Initials(string n)
    {
        var parts = n.Split(' ', StringSplitOptions.RemoveEmptyEntries);
        return string.Concat(parts.Take(2).Select(w => char.ToUpper(w[0])));
    }
}

<div class="page-head">
    <h1 class="page-title">Orders</h1>
    @if (Model.NewCount > 0)
    {
        <span class="badge prospect">@Model.NewCount new</span>
    }
</div>
<p class="page-sub">Requests placed from the website. WhatsApp is still the main chat.</p>

@if (Model.Orders.Count == 0)
{
    <div class="empty">No website orders yet.</div>
}
else
{
    <div class="list">
        @foreach (var o in Model.Orders)
        {
            <div class="list-row" style="flex-wrap:wrap">
                <span class="avatar @(o.Status == OrderStatus.New ? "" : "ghost")">@Initials(o.CustomerName)</span>
                <span class="row-main">
                    <span class="primary">@o.CustomerName <span class="badge @o.Status.Badge()">@o.Status.Label()</span></span><br />
                    <span class="secondary">
                        @if (!string.IsNullOrWhiteSpace(o.ProductName))
                        {
                            <strong>@o.ProductName</strong> <span>·</span>
                        }
                        <a href="tel:@o.Phone">@o.Phone</a> · @o.CreatedAt.ToLocalTime().ToString("dd MMM HH:mm")
                    </span>
                    @if (!string.IsNullOrWhiteSpace(o.Details))
                    {
                        <br /><span class="secondary" style="white-space:pre-wrap">@o.Details</span>
                    }
                </span>
                <span class="order-actions">
                    @foreach (var s in statuses)
                    {
                        @if (s != o.Status)
                        {
                            <form method="post" asp-page-handler="Status" style="margin:0">
                                <input type="hidden" name="id" value="@o.Id" />
                                <input type="hidden" name="status" value="@s" />
                                <button type="submit" class="btn btn-sm">@s.Label()</button>
                            </form>
                        }
                    }
                </span>
            </div>
        }
    </div>
}
