@page
@model AfricanSpringInventory.Pages.Orders.IndexModel
@{
    ViewData["Title"] = "Orders";
    ViewData["Tab"] = "orders";
    ViewData["Sub"] = "From the website";
}
@functions {
    static (OrderStatus? Next, string Label) NextStep(OrderStatus s) => s switch
    {
        OrderStatus.New => (OrderStatus.Confirmed, "Confirm"),
        OrderStatus.Confirmed => (OrderStatus.OutForDelivery, "Out for delivery"),
        OrderStatus.OutForDelivery => (OrderStatus.Delivered, "Mark delivered"),
        OrderStatus.Delivered => (OrderStatus.Paid, "Mark paid"),
        _ => (null, "")
    };
}

<div class="page-head">
    <h1 class="page-title">Orders</h1>
    @if (Model.NewCount > 0)
    {
        <span class="badge prospect">@Model.NewCount new</span>
    }
</div>
<p class="page-sub">Move an order through the workflow — Delivered writes the delivery + stock, Paid settles the balance.</p>

@if (Model.Orders.Count == 0)
{
    <div class="empty">No website orders yet.</div>
}
else
{
    @foreach (var o in Model.Orders)
    {
        var next = NextStep(o.Status);
        var total = o.Items.Sum(i => i.LineTotal);
        <div class="card" style="margin-bottom:12px">
            <div class="page-head" style="margin-bottom:6px">
                <span class="primary">@o.CustomerName <span class="badge">AS-@o.Id.ToString("D4")</span> <span class="badge @o.Status.Badge()">@o.Status.Label()</span></span>
                <span class="secondary">@o.CreatedAt.ToLocalTime().ToString("dd MMM HH:mm")</span>
            </div>
            <div class="secondary"><a href="tel:@o.Phone">@o.Phone</a></div>

            @if (o.Items.Count > 0)
            {
                <div style="margin-top:8px">
                    @foreach (var it in o.Items)
                    {
                        <div class="secondary">@it.Quantity.ToString("0.##") &times; @it.ProductName &mdash; R @it.LineTotal.ToString("N2")</div>
                    }
                    <div style="font-weight:700;margin-top:4px">Total: R @total.ToString("N2")</div>
                </div>
            }
            else if (!string.IsNullOrWhiteSpace(o.ProductName))
            {
                <div class="secondary" style="margin-top:6px"><strong>@o.ProductName</strong></div>
            }

            @if (!string.IsNullOrWhiteSpace(o.Details))
            {
                <p class="secondary" style="margin:6px 0 0;white-space:pre-wrap">@o.Details</p>
            }

            @if (o.DeliveryId is not null)
            {
                <div class="secondary" style="margin-top:8px;color:var(--ok)">Delivery logged &middot; stock deducted@(o.PaymentId is not null ? " &middot; paid" : "")</div>
            }

            <div style="display:flex;flex-wrap:wrap;gap:8px;margin-top:12px">
                @if (next.Next is OrderStatus ns)
                {
                    <form method="post" asp-page-handler="Status" style="margin:0">
                        <input type="hidden" name="id" value="@o.Id" />
                        <input type="hidden" name="status" value="@ns" />
                        <button type="submit" class="btn btn-primary btn-sm">@next.Label</button>
                    </form>
                }
                @if (o.Status != OrderStatus.Paid && o.Status != OrderStatus.Cancelled)
                {
                    <form method="post" asp-page-handler="Status" style="margin:0">
                        <input type="hidden" name="id" value="@o.Id" />
                        <input type="hidden" name="status" value="@OrderStatus.Cancelled" />
                        <button type="submit" class="btn btn-sm">Cancel</button>
                    </form>
                }
            </div>
        </div>
    }
}
