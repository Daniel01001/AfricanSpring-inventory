@inject AfricanSpringInventory.Data.AppDbContext Db
@{
    var signedIn = User.Identity?.IsAuthenticated == true;
    var tab = ViewData["Tab"] as string;
    var isOwner = User.IsInRole("Owner");
    var wide = ViewData["Wide"] as bool? == true;
    var moreTabs = new[] { "products", "fridges", "users", "activity", "more" };
    var onMore = tab is not null && moreTabs.Contains(tab);
    var newOrders = signedIn ? Db.Orders.Count(o => o.Status == OrderStatus.New) : 0;
    var appSub = ViewData["Sub"] as string;
    var hasFlowFoot = ViewData["FlowFoot"] as bool? == true;
}
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1, viewport-fit=cover" />
    <meta name="theme-color" content="@(signedIn ? "#0f1d25" : "#0f1d25")" />
    <title>@ViewData["Title"] · AfricanSpring Ice</title>
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Manrope:wght@400;500;600;700;800&display=swap" rel="stylesheet" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="manifest" href="~/manifest.webmanifest" />
    <link rel="apple-touch-icon" href="~/apple-touch-icon.png" />
</head>
<body class="shell @(signedIn ? "authed" : "unauth") @(tab is null ? "no-tabbar" : "") @(hasFlowFoot ? "has-flowfoot" : "")">
    <svg width="0" height="0" style="position:absolute" aria-hidden="true">
        <defs>
            <symbol id="i-snowflake" viewBox="0 0 24 24"><line x1="2" y1="12" x2="22" y2="12"/><line x1="12" y1="2" x2="12" y2="22"/><path d="m20 16-4-4 4-4"/><path d="m4 8 4 4-4 4"/><path d="m16 4-4 4-4-4"/><path d="m8 20 4-4 4 4"/></symbol>
            <symbol id="i-truck" viewBox="0 0 24 24"><path d="M14 18V6a2 2 0 0 0-2-2H4a2 2 0 0 0-2 2v11a1 1 0 0 0 1 1h2"/><path d="M15 18H9"/><path d="M19 18h2a1 1 0 0 0 1-1v-3.65a1 1 0 0 0-.22-.62l-3.48-4.35A1 1 0 0 0 17.52 8H14"/><circle cx="7" cy="18" r="2"/><circle cx="17" cy="18" r="2"/></symbol>
            <symbol id="i-cash" viewBox="0 0 24 24"><rect x="2" y="6" width="20" height="12" rx="2"/><circle cx="12" cy="12" r="2"/><path d="M6 12h.01M18 12h.01"/></symbol>
            <symbol id="i-store" viewBox="0 0 24 24"><path d="M4 12v8a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2v-8"/><path d="M2 7h20l-1.5 4.5a2 2 0 0 1-3.8.2 2 2 0 0 0-3.8 0 2 2 0 0 1-3.8 0 2 2 0 0 0-3.8 0 2 2 0 0 1-3.8-.2Z"/><path d="M4 3h16"/></symbol>
            <symbol id="i-dashboard" viewBox="0 0 24 24"><rect x="3" y="3" width="7" height="9" rx="1"/><rect x="14" y="3" width="7" height="5" rx="1"/><rect x="14" y="12" width="7" height="9" rx="1"/><rect x="3" y="16" width="7" height="5" rx="1"/></symbol>
            <symbol id="i-chevron" viewBox="0 0 24 24"><path d="m9 18 6-6-6-6"/></symbol>
            <symbol id="i-back" viewBox="0 0 24 24"><path d="m12 19-7-7 7-7"/><path d="M19 12H5"/></symbol>
            <symbol id="i-plus" viewBox="0 0 24 24"><path d="M5 12h14"/><path d="M12 5v14"/></symbol>
            <symbol id="i-home" viewBox="0 0 24 24"><path d="m3 9 9-7 9 7v11a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2z"/><path d="M9 22V12h6v10"/></symbol>
            <symbol id="i-box" viewBox="0 0 24 24"><path d="M21 8a2 2 0 0 0-1-1.73l-7-4a2 2 0 0 0-2 0l-7 4A2 2 0 0 0 3 8v8a2 2 0 0 0 1 1.73l7 4a2 2 0 0 0 2 0l7-4A2 2 0 0 0 21 16Z"/><path d="M3.3 7 12 12l8.7-5"/><path d="M12 22V12"/></symbol>
            <symbol id="i-users" viewBox="0 0 24 24"><path d="M16 21v-2a4 4 0 0 0-4-4H6a4 4 0 0 0-4 4v2"/><circle cx="9" cy="7" r="4"/><path d="M22 21v-2a4 4 0 0 0-3-3.87"/><path d="M16 3.13a4 4 0 0 1 0 7.75"/></symbol>
            <symbol id="i-fridge" viewBox="0 0 24 24"><rect x="5" y="2" width="14" height="20" rx="2"/><path d="M5 10h14"/><path d="M9 6v1"/><path d="M9 14v2"/></symbol>
            <symbol id="i-activity" viewBox="0 0 24 24"><path d="M22 12h-4l-3 9L9 3l-3 9H2"/></symbol>
            <symbol id="i-more" viewBox="0 0 24 24"><circle cx="12" cy="5" r="1.6"/><circle cx="12" cy="12" r="1.6"/><circle cx="12" cy="19" r="1.6"/></symbol>
            <symbol id="i-panel" viewBox="0 0 24 24"><rect x="3" y="3" width="18" height="18" rx="2"/><path d="M9 3v18"/></symbol>
            <symbol id="i-trend" viewBox="0 0 24 24"><path d="M22 7l-8.5 8.5-5-5L2 17"/><path d="M16 7h6v6"/></symbol>
            <symbol id="i-wallet" viewBox="0 0 24 24"><path d="M19 7V5a2 2 0 0 0-2-2H5a2 2 0 0 0 0 4h14a2 2 0 0 1 2 2v8a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2V5"/><path d="M18 12a1 1 0 0 0 0 2h3v-2z"/></symbol>
            <symbol id="i-order" viewBox="0 0 24 24"><path d="M9 2h6a1 1 0 0 1 1 1v1h1a2 2 0 0 1 2 2v13a2 2 0 0 1-2 2H7a2 2 0 0 1-2-2V6a2 2 0 0 1 2-2h1V3a1 1 0 0 1 1-1z"/><path d="M9 4h6"/><path d="M9 12h6"/><path d="M9 16h4"/></symbol>
            <symbol id="i-bell" viewBox="0 0 24 24"><path d="M6 8a6 6 0 0 1 12 0c0 7 3 9 3 9H3s3-2 3-9"/><path d="M10.3 21a1.94 1.94 0 0 0 3.4 0"/></symbol>
        </defs>
    </svg>

    @if (signedIn)
    {
        <aside class="sidebar">
            <a class="brand" asp-page="@(isOwner ? "/Dashboard" : "/Index")">
                <span class="brand-mark"><svg class="icon"><use href="#i-snowflake" /></svg></span>
                <span class="b-name">AfricanSpring Ice<span class="b-tag">Ice business tracker</span></span>
            </a>
            <nav class="nav">
                @if (isOwner)
                {
                    <a class="nav-item @(tab == "dashboard" ? "on" : "")" asp-page="/Dashboard">
                        <svg class="icon"><use href="#i-dashboard" /></svg> Overview
                    </a>
                }
                else
                {
                    <a class="nav-item @(tab == "home" ? "on" : "")" asp-page="/Index">
                        <svg class="icon"><use href="#i-home" /></svg> Home
                    </a>
                }
                <a class="nav-item @(tab == "activity" ? "on" : "")" asp-page="/Activity">
                    <svg class="icon"><use href="#i-activity" /></svg> Activity
                </a>
                <div class="nav-label">Business</div>
                <a class="nav-item @(tab == "orders" ? "on" : "")" asp-page="/Orders/Index">
                    <svg class="icon"><use href="#i-order" /></svg> Orders
                </a>
                <a class="nav-item @(tab == "stores" ? "on" : "")" asp-page="/Stores/Index">
                    <svg class="icon"><use href="#i-store" /></svg> Stores
                </a>
                <a class="nav-item @(tab == "stock" ? "on" : "")" asp-page="/Stock/Index">
                    <svg class="icon"><use href="#i-snowflake" /></svg> Inventory
                </a>
                <a class="nav-item @(tab == "products" ? "on" : "")" asp-page="/Products/Index">
                    <svg class="icon"><use href="#i-box" /></svg> Products
                </a>
                <a class="nav-item @(tab == "fridges" ? "on" : "")" asp-page="/Fridges/Index">
                    <svg class="icon"><use href="#i-fridge" /></svg> Fridges
                </a>
                @if (isOwner)
                {
                    <div class="nav-label">Admin</div>
                    <a class="nav-item @(tab == "users" ? "on" : "")" asp-page="/Users/Index">
                        <svg class="icon"><use href="#i-users" /></svg> People
                    </a>
                }
            </nav>
            <div class="sidebar-foot">
                <span class="who">@User.Identity!.Name<small>@(isOwner ? "Owner" : "Friend")</small></span>
                <form asp-page="/Logout" method="post" style="margin:0">
                    <button type="submit" class="link">Sign out</button>
                </form>
            </div>
        </aside>

        <header class="app-header">
            <div>
                <h1 class="ab-title">@(ViewData["Title"] ?? "AfricanSpring")</h1>
                @if (appSub is not null)
                {
                    <div class="ab-sub">@appSub</div>
                }
            </div>
            <a class="iconbtn" asp-page="/Orders/Index" aria-label="Orders">
                <svg class="icon"><use href="#i-bell" /></svg>
                @if (newOrders > 0)
                {
                    <span class="dot"></span>
                }
            </a>
        </header>
    }

    <div class="content">
        @if (signedIn)
        {
            <div class="topbar">
                <svg class="icon tb-icon"><use href="#i-panel" /></svg>
                <span class="tb-sep">|</span>
                <span class="tb-crumb">@(ViewData["Title"] ?? "AfricanSpring Ice")</span>
            </div>
        }
        <main class="container @(wide ? "wide" : "")">
            @RenderBody()
        </main>
    </div>

    @if (signedIn && tab is not null)
    {
        <nav class="tabbar">
            @if (isOwner)
            {
                <a class="tab @(tab == "dashboard" ? "on" : "")" asp-page="/Dashboard">
                    <svg class="icon"><use href="#i-dashboard" /></svg><span>Overview</span>
                </a>
            }
            else
            {
                <a class="tab @(tab == "home" ? "on" : "")" asp-page="/Index">
                    <svg class="icon"><use href="#i-home" /></svg><span>Home</span>
                </a>
            }
            <a class="tab @(tab == "stores" ? "on" : "")" asp-page="/Stores/Index">
                <svg class="icon"><use href="#i-store" /></svg><span>Stores</span>
            </a>
            <a class="tab @(tab == "stock" ? "on" : "")" asp-page="/Stock/Index">
                <svg class="icon"><use href="#i-snowflake" /></svg><span>Stock</span>
            </a>
            <a class="tab @(tab == "orders" ? "on" : "")" asp-page="/Orders/Index">
                <svg class="icon"><use href="#i-order" /></svg><span>Orders</span>
                @if (newOrders > 0)
                {
                    <span class="tab-badge">@newOrders</span>
                }
            </a>
            <a class="tab @(onMore ? "on" : "")" asp-page="/More">
                <svg class="icon"><use href="#i-more" /></svg><span>More</span>
            </a>
        </nav>
    }
    @if (signedIn)
    {
        <script src="~/js/push.js" asp-append-version="true"></script>
    }
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
