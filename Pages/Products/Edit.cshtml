@page
@model AfricanSpringInventory.Pages.Products.EditModel
@{
    ViewData["Title"] = "Edit product";
}

<a class="back" asp-page="/Products/Index"><svg class="icon"><use href="#i-back" /></svg> Products</a>
<h1 class="page-title">Edit product</h1>

<form method="post">
    <input type="hidden" asp-for="Product.Id" />

    <div class="field">
        <label asp-for="Product.Name">Name</label>
        <input asp-for="Product.Name" />
        <span asp-validation-for="Product.Name" class="field-error"></span>
    </div>

    <div class="field-row">
        <div class="field">
            <label asp-for="Product.UnitType">Sold as</label>
            <input asp-for="Product.UnitType" />
        </div>
        <div class="field">
            <label asp-for="Product.UnitPrice">Price (R)</label>
            <input asp-for="Product.UnitPrice" type="number" min="0" step="0.01" inputmode="decimal" />
        </div>
    </div>

    <div class="field">
        <label asp-for="Product.ReorderThreshold">Low-stock alert at (units, 0 = off)</label>
        <input asp-for="Product.ReorderThreshold" type="number" min="0" step="0.01" inputmode="decimal" />
    </div>

    <label class="toggle">
        <input type="checkbox" asp-for="Product.IsActive" />
        <span>Available for deliveries</span>
    </label>

    <div class="action-bar">
        <button class="btn btn-primary btn-block" type="submit">Save changes</button>
    </div>
</form>
