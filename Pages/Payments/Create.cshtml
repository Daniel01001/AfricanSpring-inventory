@page
@model AfricanSpringInventory.Pages.Payments.CreateModel
@{
    ViewData["Title"] = "Record payment";
}

<a class="back" asp-page="/Index"><svg class="icon"><use href="#i-back" /></svg> Home</a>
<h1 class="page-title">Record payment</h1>
<p class="page-sub">Reduces the store's outstanding balance.</p>

<form method="post">
    <div class="field">
        <label asp-for="StoreId">Store</label>
        <select asp-for="StoreId" asp-items="Model.Stores">
            <option value="">Select a store…</option>
        </select>
    </div>

    <div class="field">
        <label asp-for="Amount">Amount (R)</label>
        <input asp-for="Amount" type="number" min="0" step="0.01" inputmode="decimal" placeholder="0.00" />
    </div>

    <div class="field-row">
        <div class="field">
            <label asp-for="PaymentDate">Date</label>
            <input asp-for="PaymentDate" type="date" />
        </div>
        <div class="field">
            <label asp-for="Method">Method</label>
            <select asp-for="Method">
                @foreach (var v in Enum.GetValues<PaymentMethod>())
                {
                    <option value="@v">@v.Label()</option>
                }
            </select>
        </div>
    </div>

    <div class="field">
        <label asp-for="Notes">Notes</label>
        <textarea asp-for="Notes" placeholder="Optional"></textarea>
    </div>

    @if (Model.Error is not null)
    {
        <p class="field-error">@Model.Error</p>
    }

    <div class="action-bar">
        <button class="btn btn-primary btn-block" type="submit">Save payment</button>
    </div>
</form>
