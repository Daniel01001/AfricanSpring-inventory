@page
@model AfricanSpringInventory.Pages.Stores.DetailsModel
@{
    ViewData["Title"] = Model.Store.Name;
    ViewData["Tab"] = "stores";
}

<a class="back" asp-page="/Stores/Index"><svg class="icon"><use href="#i-back" /></svg> Stores</a>

<div class="page-head">
    <h1 class="page-title">@Model.Store.Name</h1>
    <a class="add-link" asp-page="/Stores/Edit" asp-route-id="@Model.Store.Id">Edit</a>
</div>

<div class="pill-row" style="margin-bottom:16px">
    <span class="badge @Model.Store.Status.Badge()">@Model.Store.Status.Label()</span>
    <span class="badge">@Model.Store.FridgeArrangement.Label()</span>
</div>

<div class="balance" style="margin-bottom:12px">
    <div>
        <div class="b-label">Outstanding</div>
        <div class="b-value @(Model.Outstanding > 0 ? "owe" : "ok")">R @Model.Outstanding.ToString("N2")</div>
    </div>
    <div>
        <div class="b-label">Delivered to date</div>
        <div class="b-value">R @Model.TotalDelivered.ToString("N2")</div>
    </div>
</div>

<div class="action-grid" style="margin-top:12px">
    <a class="btn btn-primary" asp-page="/Deliveries/Create" asp-route-storeId="@Model.Store.Id">Log delivery</a>
    <a class="btn" asp-page="/Payments/Create" asp-route-storeId="@Model.Store.Id">Record payment</a>
</div>

<div class="section-label">Online ordering access</div>
@if (Model.AccessError is not null)
{
    <p class="field-error">@Model.AccessError</p>
}
@if (Model.GrantedPassword is not null)
{
    <div class="card" style="border:1px solid var(--accent);background:var(--accent-soft)">
        <div style="font-weight:800;margin-bottom:2px">Temporary password created</div>
        <div class="secondary">Send it now — it won't be shown again.</div>
        <div style="display:flex;gap:24px;margin:12px 0">
            <div><div class="secondary">Phone</div><div style="font-weight:700" class="num">@Model.GrantedPhone</div></div>
            <div><div class="secondary">Password</div><div style="font-weight:800;letter-spacing:.06em">@Model.GrantedPassword</div></div>
        </div>
        <a class="btn btn-primary btn-block" href="https://wa.me/@((Model.GrantedPhone ?? "").TrimStart('+'))?text=@(Uri.EscapeDataString($"Here's your AfricanSpring online-ordering login for orders.africanspring.co.za\nPhone: {Model.GrantedPhone}\nPassword: {Model.GrantedPassword}\nPlease change your password when you first log in."))" target="_blank" rel="noopener">Send on WhatsApp</a>
    </div>
}
@if (Model.Account is not null)
{
    <div class="card">
        <div style="display:flex;align-items:center;gap:10px">
            <span class="avatar"><svg class="icon"><use href="#i-users" /></svg></span>
            <div style="flex:1">
                <div style="font-weight:700">@Model.Account.Name</div>
                <div class="secondary">@Model.Account.Phone · @(Model.Account.IsActive ? "active" : "disabled")@(Model.Account.MustChangePassword ? " · temp password" : "")</div>
            </div>
        </div>
        <form method="post" asp-page-handler="ResetPassword" asp-route-id="@Model.Store.Id" style="margin-top:12px">
            <button type="submit" class="btn btn-block">Reset password</button>
        </form>
    </div>
}
else
{
    <div class="card">
        <p class="secondary" style="margin:0 0 12px">
            Let this store order online. We'll create a login for
            @(string.IsNullOrWhiteSpace(Model.Store.Phone) ? "their phone" : Model.Store.Phone)
            and give you a password to send on WhatsApp.
        </p>
        <form method="post" asp-page-handler="GrantAccess" asp-route-id="@Model.Store.Id">
            <button type="submit" class="btn btn-primary btn-block">Give online access</button>
        </form>
    </div>
}

@if (Model.Store.ContactPerson is not null || Model.Store.Phone is not null || Model.Store.Location is not null)
{
    <div class="section-label">Contact</div>
    <div class="card">
        <dl class="dl">
            @if (!string.IsNullOrWhiteSpace(Model.Store.ContactPerson))
            {
                <div class="row"><dt>Person</dt><dd>@Model.Store.ContactPerson</dd></div>
            }
            @if (!string.IsNullOrWhiteSpace(Model.Store.Phone))
            {
                <div class="row"><dt>Phone</dt><dd><a href="tel:@Model.Store.Phone">@Model.Store.Phone</a></dd></div>
            }
            @if (!string.IsNullOrWhiteSpace(Model.Store.Location))
            {
                <div class="row"><dt>Location</dt><dd>@Model.Store.Location</dd></div>
            }
        </dl>
    </div>
}

@if (!string.IsNullOrWhiteSpace(Model.Store.Notes))
{
    <div class="section-label">Notes</div>
    <div class="card muted">@Model.Store.Notes</div>
}

<div class="section-label">Recent deliveries</div>
@if (Model.Deliveries.Count == 0)
{
    <div class="empty">No deliveries yet.</div>
}
else
{
    <div class="list">
        @foreach (var d in Model.Deliveries)
        {
            <div class="list-row">
                <span class="row-main">
                    <span class="primary">@d.Date.ToString("ddd, dd MMM")</span><br />
                    <span class="secondary">by @d.By</span>
                </span>
                <span class="amount">R @d.Total.ToString("N2")</span>
            </div>
        }
    </div>
}

<div class="section-label">Recent payments</div>
@if (Model.Payments.Count == 0)
{
    <div class="empty">No payments yet.</div>
}
else
{
    <div class="list">
        @foreach (var p in Model.Payments)
        {
            <div class="list-row">
                <span class="row-main">
                    <span class="primary">@p.PaymentDate.ToString("ddd, dd MMM")</span><br />
                    <span class="secondary">@p.Method.Label()</span>
                </span>
                <span class="amount" style="color:var(--ok)">R @p.Amount.ToString("N2")</span>
            </div>
        }
    </div>
}
